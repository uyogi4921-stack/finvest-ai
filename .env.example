# ─── Finvest AI server (server.js) ───────────────────────
# Copy to .env (or export in your shell) before `npm start`.

# Optional: enable the real Claude-powered Fin tutor. Without this key the app
# automatically uses its built-in offline answer engine — Fin still works.
ANTHROPIC_API_KEY=

# Model used for Fin when a key is set (default: claude-haiku-4-5-20251001).
# Use claude-sonnet-4-6 or claude-opus-4-8 for deeper answers at higher cost.
FINVEST_MODEL=claude-haiku-4-5-20251001

# Admin panel password (default: finvest2024) and server port (default: 3000).
ADMIN_PASS=
PORT=3000
